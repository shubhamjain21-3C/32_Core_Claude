# ============================================================
# 3C Core — Environment Variables Example
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- App ---
NEXT_PUBLIC_SITE_URL=https://3ccore.com
NEXT_PUBLIC_COMPANY_EMAIL=contactus@3ccore.com

# --- NextAuth ---
NEXTAUTH_URL=https://3ccore.com
NEXTAUTH_SECRET=run_openssl_rand_base64_32_to_generate

# --- Portal Credentials ---
PORTAL_ADMIN_EMAIL=admin@3ccore.com
PORTAL_ADMIN_PASSWORD=change_this_password

# --- Resend (Email) ---
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=contactus@3ccore.com

# --- Supabase ---
# Required for Supabase Auth email OTP verification used during account creation.
# Get these from Supabase Dashboard → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Set to "true" once an SMS provider (Twilio / MessageBird / Vonage) is
# connected in Supabase Dashboard → Authentication → Providers → Phone.
# Default is false — phone field is captured but verification is gated.
NEXT_PUBLIC_PHONE_OTP_ENABLED=false

# --- Anthropic (Claude AI — inventory analysis) ---
# Server-side key — required only when AI analysis is enabled.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# Optional override of the Claude model used for inventory analysis.
ANTHROPIC_MODEL=claude-sonnet-4-6
# Set to "true" to turn on Claude-powered analysis on the DIY inventory page.
# Defaults to false — the page works end-to-end with a stubbed analysis.
NEXT_PUBLIC_AI_ANALYSIS_ENABLED=false

# --- Stripe (payments) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
